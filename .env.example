# Copy this file to `.env` and fill in your own keys.
# DO NOT commit `.env` — it is gitignored.

# Choose provider: google | elevenlabs
TTS_PROVIDER=elevenlabs

# Google Cloud TTS (Vietnamese native voices)
# Voice options: vi-VN-Wavenet-A (female), vi-VN-Wavenet-B (male),
#                vi-VN-Wavenet-C (female), vi-VN-Wavenet-D (male, recommended)
GOOGLE_TTS_API_KEY=
GOOGLE_TTS_VOICE_ID=vi-VN-Wavenet-D

# ElevenLabs (Pro plan unlocks library voices)
# Default voices (free tier): pNInz6obpgDQGcFmaJgB (Adam), IKne3meq5aSn9XLyUdCD (Charlie)
# Vietnamese library voice (Pro): 3VnrjnYrskPMDsapTr8X (Tung Dang)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=3VnrjnYrskPMDsapTr8X
# Model: eleven_v3 (latest), eleven_multilingual_v2 (older)
ELEVENLABS_MODEL_ID=eleven_v3
